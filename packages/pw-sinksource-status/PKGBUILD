# Maintainer: Nikolay Arhipovs <n@arhipov.net>
pkgname=pw-sinksource-status
pkgver=0.0.1
pkgrel=1
pkgdesc="PipeWire audio status tool for waybar/i3status-rs"
arch=('x86_64' 'aarch64')
url="https://github.com/nikarh/dotfiles-tools/"
license=('MIT')
depends=('pipewire')
makedepends=('gcc' 'pkgconf')
source=('pw-sinksource-status.c')
sha256sums=('d44506a261785707113f4a64939c0655d5998f1af629c8a17ae94844f46a4ea6')

build() {
  local pw_flags
  pw_flags=$(pkg-config --cflags --libs libpipewire-0.3)
  gcc -s -Wall -O3 -o pw-sinksource-status pw-sinksource-status.c ${pw_flags}
}

package() {
  install -Dm755 pw-sinksource-status "$pkgdir/usr/bin/pw-sinksource-status"
}
